---
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const countSuffix = { ja: '件', en: ' projects' } as const;

interface TimelineItem {
  period: { ja: string; en: string };
  title: { ja: string; en: string };
  description?: { ja: string; en: string };
  tags?: string[];
  children?: TimelineItem[];
}

const personalItems: TimelineItem[] = [
  {
    period: { ja: '2004年6月2日', en: 'Jun 2, 2004' },
    title: { ja: '富山県富山市 生まれ', en: 'Born in Toyama City, Toyama' },
  },
  {
    period: { ja: '2020年4月 〜 2023年3月', en: 'Apr 2020 – Mar 2023' },
    title: {
      ja: '富山県立富山東高校',
      en: 'Toyama Higashi High School',
    },
    description: {
      ja: 'サッカー部',
      en: 'Soccor Club',
    },
  },
  {
    period: { ja: '2023年4月 〜 現在', en: 'Apr 2023 – Present' },
    title: {
      ja: '信州大学 工学部 電子情報システム工学科',
      en: 'Shinshu University, Dept. of Electrical & Computer Engineering',
    },
    description: {
      ja: '情報プログラム所属。アルゴリズム・データ構造、OS、コンピュータネットワーク、データベース、機械学習など情報系の基礎を幅広く学んでいる。',
      en: 'Information Program. Studying a broad range of CS fundamentals including algorithms & data structures, operating systems, networking, databases, and machine learning.',
    },
  },
];

const workItems: TimelineItem[] = [
  {
    period: { ja: '2024年3月〜現在', en: 'Mar 2024 – Present' },
    title: {
      ja: 'スタートアップ インターン参加',
      en: 'Joined Startup as Intern',
    },
    children: [
      {
        period: { ja: '2024年3月〜2024年8月', en: 'Mar – Aug 2024' },
        title: {
          ja: '広告データ分析ダッシュボードの構築',
          en: 'Advertising Analytics Dashboard',
        },
        description: {
          ja: '広告データ等を可視化する分析ダッシュボードを作成。troccoでデータパイプラインを構築しBigQueryへ転送・加工。Looker StudioでBIダッシュボードを構築した。',
          en: 'Built analytics dashboards to visualize advertising data. Constructed data pipelines with trocco, transferred and transformed data in BigQuery, and created BI dashboards with Looker Studio.',
        },
        tags: ['BigQuery', 'trocco', 'Looker Studio'],
      },
      {
        period: { ja: '2024年9月〜2025年2月', en: 'Sep 2024 – Feb 2025' },
        title: {
          ja: '分析ダッシュボードSaaS開発・デプロイ自動化',
          en: 'Analytics Dashboard SaaS & Deploy Automation',
        },
        description: {
          ja: 'データを可視化する自社ウェブアプリの開発に参加。可視化のためのSQLクエリ作成と、TerraformベースのCloud RunデプロイをShellスクリプトで自動化し、手作業3〜5分の作業を1コマンド・1分以内に短縮した。',
          en: 'Joined development of an in-house data visualization web app. Wrote analytics SQL queries and automated the Terraform-based Cloud Run deployment flow with a shell script, reducing a 3–5 min manual process to under 1 minute with a single command.',
        },
        tags: [
          'TypeScript',
          'Hono.js',
          'Next.js',
          'GraphQL',
          'Terraform',
          'Cloud Run',
          'BigQuery',
          'Prisma',
        ],
      },
      {
        period: { ja: '2025年1月〜2025年2月', en: 'Jan – Feb 2025' },
        title: {
          ja: 'Slack AIアシスタント開発（0から構築）',
          en: 'Slack AI Assistant (Built from Scratch)',
        },
        description: {
          ja: 'Slackでの議論にAIが参加できるボットを0から構築。現在はインサイドセールスのアポイント管理スレッドで活用され、100件超の会話履歴を踏まえた返答で業務効率化に貢献している。社外チャンネルへの未返信メッセージに対するリマインド機能も実装。',
          en: 'Built a Slack bot from scratch that joins team discussions with AI. Now used in inside sales threads to respond based on 100+ message histories, improving team efficiency. Also implemented unreplied message reminders for external Slack channels.',
        },
        tags: ['Python', 'FastAPI', 'LangGraph', 'Slack API', 'Cloud Run', 'Cloud Tasks'],
      },
      {
        period: { ja: '2025年4月〜2025年6月', en: 'Apr – Jun 2025' },
        title: {
          ja: 'AIエージェントBEを0から設計・開発',
          en: 'AI Agent Backend — Designed & Built from Scratch',
        },
        description: {
          ja: '人材プラットフォームにAIチャット機能を提供するBEを0から開発。複数エージェント（Dify / LangGraph）を1エンドポイントで管理する設計を自分で立案し、エンジニアと議論しながら技術選定・CI/CD構築・Firestore導入まで担当した。',
          en: 'Designed and built a backend from scratch to provide AI chat for an HR platform. Architected a single-endpoint system managing multiple agents (Dify / LangGraph), and handled tech selection, CI/CD setup, and Firestore integration.',
        },
        tags: ['Python', 'FastAPI', 'Firestore', 'Cloud Run', 'Docker'],
      },
      {
        period: { ja: '2025年9月〜現在', en: 'Sep 2025 – Present' },
        title: {
          ja: 'マーケティングを支えるSaaS開発',
          en: 'Marketing SaaS Development',
        },
        description: {
          ja: 'AIで広告クリエイティブを作成・編集したり、広告データの分析を支援するSaaSの開発に参加。n8n内で動いていたChromiumをBrowserlessで外部に切り出してCloud Run上に独立させ、メモリ不足によるワークフロー停止を解消した。MastraからAI SDKへの移行も検討し、PoCとして実装。広告データを取得してBigQueryに流すパイプラインも構築した。また、FigmaプラグインでHTMLをインポートできるPoCも担当した。',
          en: 'Joined a SaaS product that helps marketers create and edit ad creatives with AI and analyze ad data. Moved Chromium out of n8n into a standalone Browserless service on Cloud Run, fixing workflow crashes caused by memory pressure. Built a PoC for migrating from Mastra to AI SDK as a potential new agent foundation. Also built a data pipeline to pull advertising data into BigQuery, and created a Figma plugin PoC for importing HTML.',
        },
        tags: [
          'TypeScript',
          'Next.js',
          'React',
          'Tailwind CSS',
          'Hono.js',
          'tRPC',
          'Prisma',
          'NeonDB',
          'Vercel',
          'Cloud Run',
        ],
      },
    ],
  },
];
---

<section id="experience" class="border-divider border-t py-24">
  <div class="mx-auto max-w-4xl px-6">
    <h2 data-animate class="text-foreground mb-12 text-2xl font-bold">{t('experience.title')}</h2>

    <div class="relative">
      <!-- Vertical line -->
      <div class="bg-outline absolute top-0 bottom-0 left-1.75 w-px"></div>

      <ol class="space-y-10">
        <!-- Personal background items -->
        {
          personalItems.map((item, i) => (
            <li
              data-animate
              style={`transition-delay: ${i * 80}ms`}
              class="relative flex gap-6 pl-8"
            >
              <div class="border-outline bg-background absolute top-1.5 left-0 h-3.75 w-3.75 rounded-full border-2" />
              <div class="min-w-0 flex-1">
                <p class="text-tertiary mb-1 text-xs font-medium">{item.period[lang]}</p>
                <h3 class="text-foreground text-sm font-semibold">{item.title[lang]}</h3>
                {item.description && (
                  <p class="text-secondary text-sm leading-relaxed">{item.description[lang]}</p>
                )}
              </div>
            </li>
          ))
        }

        <!-- Work items -->
        {
          workItems.map((item, i) =>
            item.children ? (
              <li
                data-animate
                style={`transition-delay: ${(personalItems.length + i) * 80}ms`}
                class="relative flex gap-6 pl-8"
              >
                <div class="border-outline-strong bg-background absolute top-1.5 left-0 h-3.75 w-3.75 rounded-full border-2" />
                <div class="min-w-0 flex-1">
                  <details class="group">
                    <summary class="hover:bg-tag -mx-2 cursor-pointer list-none rounded-lg px-2 py-2 transition-colors duration-150">
                      <p class="text-tertiary mb-1 text-xs font-medium">{item.period[lang]}</p>
                      <div class="mb-2 flex items-center gap-2">
                        <h3 class="text-foreground text-sm font-semibold">{item.title[lang]}</h3>
                        {item.children && (
                          <span class="bg-tag text-tag-fg rounded-full px-2 py-0.5 text-xs font-medium">
                            {item.children.length}
                            {countSuffix[lang]}
                          </span>
                        )}
                        <span class="bg-tag text-tag-fg ml-auto flex h-5 w-5 shrink-0 items-center justify-center rounded-full">
                          <svg
                            class="h-3 w-3 transition-transform duration-200 group-open:rotate-180"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                              clip-rule="evenodd"
                            />
                          </svg>
                        </span>
                      </div>
                      {item.description && (
                        <p class="text-secondary mb-3 text-sm leading-relaxed">
                          {item.description[lang]}
                        </p>
                      )}
                      {item.tags && (
                        <div class="flex flex-wrap gap-1.5">
                          {item.tags.map((tag) => (
                            <span class="bg-tag text-tag-fg rounded-full px-2.5 py-0.5 text-xs font-medium">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </summary>

                    <div class="mt-6 ml-4">
                      <div class="relative">
                        <div class="bg-outline absolute top-0 bottom-0 left-1.5 w-px" />
                        <ol class="space-y-6">
                          {item.children.map((child) => (
                            <li class="relative flex gap-4 pl-7">
                              <div class="border-outline bg-background absolute top-1.25 left-0 h-3.25 w-3.25 rounded-full border-2" />
                              <div class="min-w-0 flex-1">
                                <p class="text-tertiary mb-1 text-xs font-medium">
                                  {child.period[lang]}
                                </p>
                                <h4 class="text-foreground mb-2 text-sm font-semibold">
                                  {child.title[lang]}
                                </h4>
                                {child.description && (
                                  <p class="text-secondary mb-3 text-sm leading-relaxed">
                                    {child.description[lang]}
                                  </p>
                                )}
                                {child.tags && (
                                  <div class="flex flex-wrap gap-1.5">
                                    {child.tags.map((tag) => (
                                      <span class="bg-tag text-tag-fg rounded-full px-2.5 py-0.5 text-xs font-medium">
                                        {tag}
                                      </span>
                                    ))}
                                  </div>
                                )}
                              </div>
                            </li>
                          ))}
                        </ol>
                      </div>
                    </div>
                  </details>
                </div>
              </li>
            ) : (
              <li
                data-animate
                style={`transition-delay: ${(personalItems.length + i) * 80}ms`}
                class="relative flex gap-6 pl-8"
              >
                <div class="border-outline-strong bg-background absolute top-1.5 left-0 h-3.75 w-3.75 rounded-full border-2" />
                <div class="min-w-0 flex-1">
                  <p class="text-tertiary mb-1 text-xs font-medium">{item.period[lang]}</p>
                  <h3 class="text-foreground mb-2 text-sm font-semibold">{item.title[lang]}</h3>
                  {item.description && (
                    <p class="text-secondary mb-3 text-sm leading-relaxed">
                      {item.description[lang]}
                    </p>
                  )}
                  {item.tags && (
                    <div class="flex flex-wrap gap-1.5">
                      {item.tags.map((tag) => (
                        <span class="bg-tag text-tag-fg rounded-full px-2.5 py-0.5 text-xs font-medium">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </li>
            ),
          )
        }
      </ol>
    </div>
  </div>
</section>
