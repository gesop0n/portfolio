---
import type { Lang } from '../i18n/translations';
import { useTranslations, getLocalePath } from '../i18n/translations';
import { calcAge } from '../lib/date/calcAge';
import { BIRTHDAY } from '../config/profile';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const name = lang === 'ja' ? '石黒 康太' : 'Kota Ishikuro';
const nameVal = lang === 'ja' ? '"石黒 康太"' : '"Kota Ishikuro"';
const age = calcAge(BIRTHDAY);
const lineCount = 12;
---

<section class="flex min-h-screen items-center pt-14">
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 px-6 py-24 lg:grid-cols-[2fr_3fr]"
  >
    <!-- Left: text content -->
    <div>
      <p class="mb-4 text-sm font-medium tracking-widest text-blue-600 uppercase">
        {lang === 'ja' ? 'エンジニア' : 'Engineer'}
      </p>

      <h1 class="mb-4 text-5xl leading-tight font-bold text-gray-900 sm:text-6xl">
        {name}
      </h1>

      <p class="mb-6 text-xl text-gray-500">
        {t('hero.role')}
      </p>

      <p class="mb-10 max-w-xl text-base leading-relaxed text-gray-600">
        {t('hero.description')}
      </p>

      <div class="flex items-center gap-4">
        <a
          href={`${getLocalePath(lang)}#contact`}
          class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-gray-700"
        >
          {t('hero.contact')}
        </a>
        <a
          href="https://github.com/Kota-35"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:border-gray-400 hover:text-gray-900"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          {t('hero.github')}
        </a>
      </div>
    </div>

    <!-- Right: Haskell code block -->
    <div class="w-full overflow-hidden rounded-xl bg-[#1e1e2e] font-mono text-sm shadow-2xl">
      <!-- Title bar -->
      <div class="flex items-center gap-2 border-b border-[#313244] bg-[#181825] px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-[#f38ba8]"></span>
        <span class="h-3 w-3 rounded-full bg-[#fab387]"></span>
        <span class="h-3 w-3 rounded-full bg-[#a6e3a1]"></span>
        <span class="ml-3 text-xs text-[#6c7086]">Engineer.hs</span>
      </div>

      <!-- Code body -->
      <div class="px-6 py-5 text-[13px] sm:text-sm">
        <div class="flex gap-5">
          <!-- Line numbers -->
          <div class="min-w-[1.5rem] shrink-0 text-right leading-7 text-[#45475a] select-none">
            {Array.from({ length: lineCount }, (_, i) => <div>{i + 1}</div>)}
          </div>

          <!-- Code lines -->
          <div class="overflow-x-auto leading-7">
            <!-- 1: data Engineer = Engineer -->
            <div>
              <span class="text-[#cba6f7]">data </span>
              <span class="text-[#89b4fa]">Engineer</span>
              <span class="text-[#cdd6f4]"> = </span>
              <span class="text-[#89b4fa]">Engineer</span>
            </div>

            <!-- 2:   { name     :: String -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;&#123; </span>
              <span class="text-[#89dceb]">name</span>
              <span class="text-[#cdd6f4]"> :: </span>
              <span class="text-[#89b4fa]">String</span>
            </div>

            <!-- 3:   , age      :: Int -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;, </span>
              <span class="text-[#89dceb]">age</span>
              <span class="text-[#cdd6f4]"> :: </span>
              <span class="text-[#89b4fa]">Int</span>
            </div>

            <!-- 4:   , location :: String -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;, </span>
              <span class="text-[#89dceb]">location</span>
              <span class="text-[#cdd6f4]"> :: </span>
              <span class="text-[#89b4fa]">String</span>
            </div>

            <!-- 5:   } deriving (Show) -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;&#125; </span>
              <span class="text-[#cba6f7]">deriving </span>
              <span class="text-[#cdd6f4]">(</span>
              <span class="text-[#89b4fa]">Show</span>
              <span class="text-[#cdd6f4]">)</span>
            </div>

            <!-- 6: (blank) -->
            <div>&nbsp;</div>

            <!-- 7: me :: Engineer -->
            <div>
              <span class="text-[#89dceb]">me</span>
              <span class="text-[#cdd6f4]"> :: </span>
              <span class="text-[#89b4fa]">Engineer</span>
            </div>

            <!-- 8: me = Engineer -->
            <div>
              <span class="text-[#89dceb]">me</span>
              <span class="text-[#cdd6f4]"> = </span>
              <span class="text-[#89b4fa]">Engineer</span>
            </div>

            <!-- 9:   { name     = "Kota Ishikuro" -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;&#123; </span>
              <span class="text-[#89dceb]">name</span>
              <span class="text-[#cdd6f4]"> = </span>
              <span class="text-[#a6e3a1]">{nameVal}</span>
            </div>

            <!-- 10:   , age      = 21 -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;, </span>
              <span class="text-[#89dceb]">age</span>
              <span class="text-[#cdd6f4]"> = </span>
              <span class="text-[#fab387]">{age}</span>
            </div>

            <!-- 11:   , location = "Japan, Nagano" -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;, </span>
              <span class="text-[#89dceb]">location</span>
              <span class="text-[#cdd6f4]"> = </span>
              <span class="text-[#a6e3a1]">"Japan, Nagano"</span>
            </div>

            <!-- 12:   } -->
            <div>
              <span class="text-[#cdd6f4]">&nbsp;&nbsp;&#125;</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
