---

<div
  class="code-block w-full overflow-hidden rounded-xl bg-[#eff1f5] font-mono text-sm shadow-2xl select-none dark:bg-[#1e1e2e]"
>
  <!-- Title bar -->
  <div
    class="flex items-center gap-2 border-b border-[#ccd0da] bg-[#e6e9ef] px-4 py-3 dark:border-[#313244] dark:bg-[#181825]"
  >
    <span class="h-3 w-3 rounded-full bg-[#f38ba8]"></span>
    <span class="h-3 w-3 rounded-full bg-[#fab387]"></span>
    <span class="h-3 w-3 rounded-full bg-[#a6e3a1]"></span>
    <span id="code-filename" class="ml-3 text-xs text-[#9ca0b0] dark:text-[#6c7086]">
      {snippets[0].filename}
    </span>
    <!-- Language badge + cycle button -->
    <button
      id="cycle-btn"
      title="次の言語へ"
      class="ml-auto flex cursor-pointer items-center gap-1.5 rounded px-2 py-0.5 text-xs text-[#9ca0b0] transition-colors hover:bg-[#ccd0da] hover:text-[#4c4f69] dark:text-[#6c7086] dark:hover:bg-[#313244] dark:hover:text-[#cdd6f4]"
    >
      <span id="code-lang">{snippets[0].lang}</span>
      <!-- Lucide RefreshCw -->
      <svg
        width="11"
        height="11"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
        <path d="M21 3v5h-5"></path>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
        <path d="M8 16H3v5"></path>
      </svg>
    </button>
  </div>

  <!-- Code body: all snippets rendered, JS shows one at a time -->
  <div class="px-6 py-5 text-[13px] sm:text-sm">
    {
      snippets.map((snippet, i) => (
        <div
          id={`snippet-${i}`}
          data-filename={snippet.filename}
          data-lang={snippet.lang}
          class:list={['flex gap-5 transition-opacity duration-200', { hidden: i !== 0 }]}
        >
          <div class="line-numbers min-w-6 shrink-0 text-right leading-7 text-[#acb0be] select-none dark:text-[#45475a]">
            {snippet.lines.map((_, j) => (
              <div>{j + 1}</div>
            ))}
          </div>
          {/* Code lines */}
          <div class="code-lines overflow-x-auto">
            {snippet.lines.map((line) => (
              <div class="leading-7">
                {line.map((token) => (
                  <span
                    class="whitespace-pre"
                    style={`color:${token.color}`}
                    set:text={token.text}
                  />
                ))}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<script
  define:vars={{
    snippetsData: snippets.map((s) => ({ lang: s.lang, filename: s.filename, lines: s.lines })),
  }}
>
  const allSnippets = Array.from(document.querySelectorAll('[id^="snippet-"]'));
  const filenameEl = document.getElementById('code-filename');
  const langEl = document.getElementById('code-lang');
  const cycleBtn = document.getElementById('cycle-btn');

  let current = 0;
  let abortController = new AbortController();

  const CHAR_DELAY_INITIAL = 15; // ms/char on page load
  const CHAR_DELAY_SWITCH = 10; // ms/char on manual switch

  function sleep(ms, signal) {
    return new Promise((resolve, reject) => {
      if (signal.aborted) {
        reject(new DOMException('Aborted'));
        return;
      }
      const id = setTimeout(resolve, ms);
      signal.addEventListener(
        'abort',
        () => {
          clearTimeout(id);
          reject(new DOMException('Aborted'));
        },
        { once: true },
      );
    });
  }

  async function typeSnippet(index, charDelay, signal) {
    const snippetEl = allSnippets[index];
    const linesEl = snippetEl.querySelector('.code-lines');
    const numsEl = snippetEl.querySelector('.line-numbers');
    if (!linesEl || !numsEl) return;

    linesEl.innerHTML = '';
    numsEl.innerHTML = '';

    const data = snippetsData[index];

    // 行番号は最初に全行分まとめて表示
    data.lines.forEach((_, i) => {
      const numDiv = document.createElement('div');
      numDiv.textContent = String(i + 1);
      numsEl.appendChild(numDiv);
    });

    try {
      for (let i = 0; i < data.lines.length; i++) {
        const lineDiv = document.createElement('div');
        lineDiv.className = 'leading-7';
        linesEl.appendChild(lineDiv);

        for (const token of data.lines[i]) {
          const span = document.createElement('span');
          span.className = 'whitespace-pre';
          span.style.color = token.color;
          lineDiv.appendChild(span);

          for (const char of token.text) {
            span.textContent += char;
            await sleep(charDelay, signal);
          }
        }
      }
    } catch {
      // typing aborted — leave partial content as-is
    }
  }

  function updateLabels(index) {
    if (filenameEl) filenameEl.textContent = snippetsData[index].filename;
    if (langEl) langEl.textContent = snippetsData[index].lang;
  }

  function switchTo(next) {
    abortController.abort();
    abortController = new AbortController();
    const signal = abortController.signal;

    const prev = allSnippets[current];
    const nextEl = allSnippets[next];

    updateLabels(next);
    current = next;

    prev.style.opacity = '0';
    setTimeout(() => {
      prev.classList.add('hidden');
      prev.style.opacity = '';

      nextEl.classList.remove('hidden');
      nextEl.style.opacity = '0';
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          nextEl.style.opacity = '1';
        }),
      );

      typeSnippet(next, CHAR_DELAY_SWITCH, signal);
    }, 200);
  }

  // コードブロックの高さをタイピング中も固定する
  const LINE_H = 28; // leading-7 = 1.75rem @ 16px base
  const fixedHeight = Math.max(...snippetsData.map((s) => s.lines.length)) * LINE_H;
  allSnippets.forEach((snippetEl) => {
    const linesEl = snippetEl.querySelector('.code-lines');
    const numsEl = snippetEl.querySelector('.line-numbers');
    if (linesEl) linesEl.style.minHeight = fixedHeight + 'px';
    if (numsEl) numsEl.style.minHeight = fixedHeight + 'px';
  });

  // 初期表示: ランダムな言語でタイピングアニメーション開始
  const initial = Math.floor(Math.random() * allSnippets.length);
  if (initial !== 0) {
    allSnippets[0].classList.add('hidden');
    allSnippets[initial].classList.remove('hidden');
    updateLabels(initial);
    current = initial;
  }
  typeSnippet(initial, CHAR_DELAY_INITIAL, abortController.signal);

  cycleBtn?.addEventListener('click', () => {
    switchTo((current + 1) % allSnippets.length);
  });
</script>

