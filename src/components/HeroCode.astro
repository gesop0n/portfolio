---
interface Props {
  nameVal: string;
  age: number;
  location: string;
}
const { nameVal, age, location } = Astro.props;

// Catppuccin Mocha (dark) / Latte (light) — switched via CSS variables
const C = {
  kw: 'var(--c-kw)',
  ty: 'var(--c-ty)',
  fi: 'var(--c-fi)',
  st: 'var(--c-st)',
  nu: 'var(--c-nu)',
  tx: 'var(--c-tx)',
} as const;

type Token = { text: string; color: string };
const t = (text: string, color: string = C.tx): Token => ({ text, color });
const blank = (): Token[] => [t('\u00a0')]; // blank line — nbsp keeps line height

const nm = nameVal; // includes quotes e.g. '"Kota Ishikuro"'
const ag = String(age);
const loc = location;

const snippets = [
  {
    lang: 'Haskell',
    filename: 'Engineer.hs',
    lines: [
      [t('data ', C.kw), t('Engineer', C.ty), t(' = '), t('Engineer', C.ty)],
      [t('  { '), t('name', C.fi), t('     :: '), t('String', C.ty)],
      [t('  , '), t('age', C.fi), t('      :: '), t('Int', C.ty)],
      [t('  , '), t('location', C.fi), t(' :: '), t('String', C.ty)],
      [t('  } '), t('deriving ', C.kw), t('('), t('Show', C.ty), t(')')],
      blank(),
      [t('me', C.fi), t(' :: '), t('Engineer', C.ty)],
      [t('me', C.fi), t(' = '), t('Engineer', C.ty)],
      [t('  { '), t('name', C.fi), t('     = '), t(nm, C.st)],
      [t('  , '), t('age', C.fi), t('      = '), t(ag, C.nu)],
      [t('  , '), t('location', C.fi), t(' = '), t(loc, C.st)],
      [t('  }')],
      blank(),
    ],
  },
  {
    lang: 'TypeScript',
    filename: 'Engineer.ts',
    lines: [
      [t('interface ', C.kw), t('Engineer ', C.ty), t('{')],
      [t('  '), t('name', C.fi), t(': '), t('string', C.ty), t(';')],
      [t('  '), t('age', C.fi), t(': '), t('number', C.ty), t(';')],
      [t('  '), t('location', C.fi), t(': '), t('string', C.ty), t(';')],
      [t('}')],
      blank(),
      [t('const ', C.kw), t('me', C.fi), t(': '), t('Engineer ', C.ty), t('= {')],
      [t('  '), t('name', C.fi), t(': '), t(nm, C.st), t(',')],
      [t('  '), t('age', C.fi), t(': '), t(ag, C.nu), t(',')],
      [t('  '), t('location', C.fi), t(': '), t(loc, C.st), t(',')],
      [t('};')],
      blank(),
      blank(),
    ],
  },
  {
    lang: 'Python',
    filename: 'engineer.py',
    lines: [
      [t('from ', C.kw), t('dataclasses', C.ty), t(' import ', C.kw), t('dataclass', C.ty)],
      blank(),
      [t('@', C.kw), t('dataclass', C.ty)],
      [t('class ', C.kw), t('Engineer', C.ty), t(':')],
      [t('    '), t('name', C.fi), t(': '), t('str', C.ty)],
      [t('    '), t('age', C.fi), t(': '), t('int', C.ty)],
      [t('    '), t('location', C.fi), t(': '), t('str', C.ty)],
      blank(),
      [t('me ', C.fi), t('= '), t('Engineer', C.ty), t('(')],
      [t('    '), t('name', C.fi), t('='), t(nm, C.st), t(',')],
      [t('    '), t('age', C.fi), t('='), t(ag, C.nu), t(',')],
      [t('    '), t('location', C.fi), t('='), t(loc, C.st), t(',')],
      [t(')')],
    ],
  },
  {
    lang: 'Rust',
    filename: 'engineer.rs',
    lines: [
      [t('struct ', C.kw), t('Engineer ', C.ty), t('{')],
