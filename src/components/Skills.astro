---
import type { Lang } from '../i18n/translations';
import type { SimpleIcon } from 'simple-icons';
import { useTranslations } from '../i18n/translations';
import {
  siTypescript,
  siRust,
  siGo,
  siHaskell,
  siScala,
  siCplusplus,
  siHono,
  siTrpc,
  siPrisma,
  siFastapi,
  siPydantic,
  siNextdotjs,
  siReact,
  siTailwindcss,
  siGooglecloud,
  siDocker,
  siTerraform,
  siVercel,
  siGooglebigquery,
  siFirebase,
  siN8n,
  siLanggraph,
} from 'simple-icons';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type Label = 'interest' | 'course';
type CustomIcon = { src: string };
type Icon = SimpleIcon | CustomIcon;

const iconMap: Record<string, Icon> = {
  TypeScript: siTypescript,
  Python: { src: '/portfolio/icons/python.svg' },
  Rust: siRust,
  Go: siGo,
  Haskell: siHaskell,
  Scala: siScala,
  'C / C++': siCplusplus,
  'Hono.js': siHono,
  tRPC: siTrpc,
  Prisma: siPrisma,
  FastAPI: siFastapi,
  Pydantic: siPydantic,
  'Next.js': siNextdotjs,
  React: siReact,
  'Tailwind CSS': siTailwindcss,
  'Cloud Run': siGooglecloud,
  Docker: siDocker,
  Terraform: siTerraform,
  Vercel: siVercel,
  BigQuery: siGooglebigquery,
  Firestore: siFirebase,
  n8n: siN8n,
  LangGraph: siLanggraph,
  Gin: { src: '/portfolio/icons/gin.svg' },
  Java: { src: '/portfolio/icons/java.svg' },
};

// Dark icons (#000000 etc.) use currentColor so they're visible in dark mode
function iconFill(hex: string): string {
  const r = parseInt(hex.slice(0, 2), 16);
  const g = parseInt(hex.slice(2, 4), 16);
  const b = parseInt(hex.slice(4, 6), 16);
  const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  return luminance < 0.2 ? 'currentColor' : `#${hex}`;
}

function isCustomIcon(icon: Icon): icon is CustomIcon {
  return 'src' in icon;
}

function renderIcon(icon: Icon, size: number): string {
  if (isCustomIcon(icon)) {
    return `<img src="${icon.src}" width="${size}" height="${size}" aria-hidden="true" style="object-fit: contain;">`;
  }
  return `<svg viewBox="0 0 24 24" width="${size}" height="${size}" aria-hidden="true" style="fill: ${iconFill(icon.hex)}"><path d="${icon.path}"/></svg>`;
}

const languageGroups: { name: string; labels: Label[]; frameworks: string[] }[] = [
  {
    name: 'TypeScript',
    labels: [],
    frameworks: ['Hono.js', 'tRPC', 'Prisma', 'Next.js', 'React', 'Tailwind CSS'],
  },
  {
    name: 'Python',
    labels: [],
    frameworks: ['FastAPI', 'Pydantic'],
  },
  {
    name: 'Go',
    labels: [],
    frameworks: ['Gin'],
  },
];

const otherLanguages: { name: string; labels: Label[] }[] = [
  { name: 'Rust', labels: ['interest'] },
  { name: 'Haskell', labels: ['interest', 'course'] },
  { name: 'Scala', labels: ['interest'] },
  { name: 'Java', labels: ['course'] },
  { name: 'C / C++', labels: ['course'] },
];

const infra = [
  'Cloud Run',
  'Docker',
  'Terraform',
  'Vercel',
  'BigQuery',
  'Firestore',
  'LangGraph',
  'n8n',
];
---

<section id="skills" class="border-divider border-t py-24">
  <div class="mx-auto max-w-4xl px-6">
    <h2 data-animate class="text-foreground mb-12 text-2xl font-bold">{t('skills.title')}</h2>

    <div class="grid gap-10 lg:grid-cols-3">
      <!-- Languages & Frameworks -->
      <div data-animate class="lg:col-span-2" style="transition-delay: 100ms">
        <h3 class="text-tertiary mb-6 text-xs font-semibold tracking-widest uppercase">
          {t('skills.lang_and_frameworks')}
        </h3>

        <div class="space-y-6">
          {
            languageGroups.map((group) => (
              <div>
                <div class="mb-2 flex items-center gap-2">
                  {iconMap[group.name] && (
                    <Fragment set:html={renderIcon(iconMap[group.name], 18)} />
                  )}
                  <span class="text-emphasis text-sm font-semibold">{group.name}</span>
                </div>
                {group.frameworks.length > 0 && (
                  <div class="border-divider border-l-2 pl-4">
                    <div class="flex flex-wrap gap-x-4 gap-y-2">
                      {group.frameworks.map((fw) => (
                        <div class="flex items-center gap-1.5">
                          {iconMap[fw] && (
                            <Fragment set:html={renderIcon(iconMap[fw], 14)} />
                          )}
                          <span class="text-secondary text-sm">{fw}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            ))
          }

          <!-- Other languages -->
          <div class="border-divider border-t pt-5">
            <h4 class="text-tertiary mb-3 text-xs font-medium tracking-wider uppercase">
              {t('skills.other_languages')}
            </h4>
            <ul class="flex flex-wrap gap-x-5 gap-y-2">
              {
                otherLanguages.map((lang_item) => (
                  <li class="flex items-center gap-1.5">
                    {iconMap[lang_item.name] && (
                      <Fragment set:html={renderIcon(iconMap[lang_item.name], 14)} />
                    )}
                    <span class="text-emphasis text-sm font-medium">{lang_item.name}</span>
                    {lang_item.labels.includes('interest') && (
                      <span class="bg-badge text-badge-fg rounded-full px-2 py-0.5 text-xs font-medium">
                        {t('skills.level.interest')}
                      </span>
                    )}
                    {lang_item.labels.includes('course') && (
                      <span class="bg-course text-course-fg rounded-full px-2 py-0.5 text-xs font-medium">
                        {t('skills.level.course')}
                      </span>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Infra -->
      <div data-animate style="transition-delay: 200ms">
        <h3 class="text-tertiary mb-6 text-xs font-semibold tracking-widest uppercase">
          {t('skills.infra')}
        </h3>
        <ul class="space-y-3">
          {
            infra.map((name) => (
              <li class="flex items-center gap-2">
                {iconMap[name] && (
                  <Fragment set:html={renderIcon(iconMap[name], 14)} />
                )}
                <span class="text-emphasis text-sm font-medium">{name}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
