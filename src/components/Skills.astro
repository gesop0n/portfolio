---
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type Label = 'interest' | 'course';

const languages: { name: string; labels: Label[] }[] = [
  { name: 'TypeScript', labels: [] },
  { name: 'Python', labels: [] },
  { name: 'Rust', labels: ['interest'] },
  { name: 'Go', labels: ['interest'] },
  { name: 'Haskell', labels: ['interest', 'course'] },
  { name: 'Scala', labels: ['interest'] },
  { name: 'Java', labels: ['course'] },
  { name: 'C / C++', labels: ['course'] },

];

const frameworks = [
  'Hono.js',
  'tRPC',
  'Prisma',
  'FastAPI',
  'Pydantic',
  'Next.js',
  'React',
  'Tailwind CSS',
];

const infra = [
  'Cloud Run',
  'Docker',
  'Terraform',
  'Vercel',
  'BigQuery',
  'Firestore',
  'LangGraph',
  'n8n',
];
---

<section id="skills" class="border-divider border-t py-24">
  <div class="mx-auto max-w-4xl px-6">
    <h2 class="text-foreground mb-12 text-2xl font-bold">{t('skills.title')}</h2>

    <div class="grid gap-10 sm:grid-cols-3">
      <!-- Languages -->
      <div>
        <h3 class="text-tertiary mb-5 text-xs font-semibold tracking-widest uppercase">
          {t('skills.languages')}
        </h3>
        <ul class="space-y-3">
          {
            languages.map((lang_item) => (
              <li class="flex items-center justify-between gap-2">
                <span class="text-emphasis text-sm font-medium">{lang_item.name}</span>
                {lang_item.labels.length > 0 && (
                  <div class="flex shrink-0 gap-1">
                    {lang_item.labels.includes('interest') && (
                      <span class="bg-badge text-badge-fg rounded-full px-2.5 py-0.5 text-xs font-medium">
                        {t('skills.level.interest')}
                      </span>
                    )}
                    {lang_item.labels.includes('course') && (
                      <span class="bg-course text-course-fg rounded-full px-2.5 py-0.5 text-xs font-medium">
                        {t('skills.level.course')}
                      </span>
                    )}
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Frameworks -->
      <div>
        <h3 class="text-tertiary mb-5 text-xs font-semibold tracking-widest uppercase">
          {t('skills.frameworks')}
        </h3>
        <ul class="space-y-3">
          {frameworks.map((name) => <li class="text-emphasis text-sm font-medium">{name}</li>)}
        </ul>
      </div>

      <!-- Infra -->
      <div>
        <h3 class="text-tertiary mb-5 text-xs font-semibold tracking-widest uppercase">
          {t('skills.infra')}
        </h3>
        <ul class="space-y-3">
          {infra.map((name) => <li class="text-emphasis text-sm font-medium">{name}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
